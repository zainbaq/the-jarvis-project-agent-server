# Next.js Environment Variables

# Public API URL (used by browser-side code for non-streaming requests)
# This should point to where the Next.js app is running since we use rewrites
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend URL for server-side proxying (use 127.0.0.1 to avoid DNS issues)
# This should point to where the FastAPI backend is running
BACKEND_URL=http://127.0.0.1:3000

# Direct backend URL for streaming endpoints (bypasses Next.js proxy buffering)
# This must be accessible from the browser for SSE streaming to work
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# AWS Cognito Configuration
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_CyRy6JBhm
NEXT_PUBLIC_COGNITO_CLIENT_ID=76dr18kllrvs9rc0bujjc5o7hh
NEXT_PUBLIC_COGNITO_REGION=us-east-2
# Cognito Hosted UI domain (REQUIRED for Hosted UI login)
# Get this from AWS Console: Cognito > User Pools > your-pool > App integration > Domain
# Format: your-prefix.auth.us-east-2.amazoncognito.com
NEXT_PUBLIC_COGNITO_DOMAIN=us-east-2cyry6jbhm.auth.us-east-2.amazoncognito.com
